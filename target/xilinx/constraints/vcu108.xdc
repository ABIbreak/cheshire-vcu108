#############
# Sys Clock #
#############

# 300 MHz input clock (SI5335A output 1, differential LVDS, G31/F31)
set SYS_TCK 3.333
create_clock -period $SYS_TCK -name sys_clk [get_ports sys_clk_p]

# SoC clock is generated by clock wizard and its constraints
set SOC_TCK 20.0
set soc_clk [get_clocks -of_objects [get_pins i_clkwiz/clk_50]]
set_property CLOCK_DEDICATED_ROUTE BACKBONE [get_nets soc_clk]

#######
# MIG #
#######

# DDR4 C1: EDY4016AABG-DR-F-D at 1333 MT/s (tCK=1500 ps).
# AXI ui_clk = 4 * tCK = 6 ns (approx. 166 MHz). Confirm after DDR4 IP generation.
set MIG_TCK 6

# False-path incoming reset
set MIG_RST_I [get_pin i_dram_wrapper/i_dram/c0_ddr4_aresetn]
set_false_path -hold -setup -through $MIG_RST_I

# Constrain outgoing reset
set MIG_RST_O [get_pins i_dram_wrapper/i_dram/c0_ddr4_ui_clk_sync_rst]
set_false_path -hold -through $MIG_RST_O
set_max_delay -through $MIG_RST_O $MIG_TCK

# Limit delay across DRAM CDC (hold already false-pathed)
# tclint-disable line-length
set_max_delay -datapath_only \
    -from [get_pins i_dram_wrapper/gen_cdc.i_axi_cdc_mig/i_axi_cdc_*/i_cdc_fifo_gray_*/*reg*/C] \
    -to [get_pins i_dram_wrapper/gen_cdc.i_axi_cdc_mig/i_axi_cdc_*/i_cdc_fifo_gray_*/*i_sync/reg*/D] $MIG_TCK
set_max_delay -datapath_only \
    -from [get_pins i_dram_wrapper/gen_cdc.i_axi_cdc_mig/i_axi_cdc_*/i_cdc_fifo_gray_*/*reg*/C] \
    -to [get_pins i_dram_wrapper/gen_cdc.i_axi_cdc_mig/i_axi_cdc_*/i_cdc_fifo_gray_*/i_spill_register/spill_register_flushable_i/*reg*/D] $MIG_TCK
# tclint-enable line-length

###############
# Assign Pins #
###############

# tclint-disable line-length, spacing

# UART (bank 67, VADJ_1V8 = 1.8 V; UG1066 Table 1-28)
set_property PACKAGE_PIN BC24     [get_ports "uart_rx_i"] ;# Bank  67 VCCO - VADJ_1V8 - IO_L11N_T1U_N9_GC_67
set_property IOSTANDARD  LVCMOS18 [get_ports "uart_rx_i"] ;# Bank  67 VCCO - VADJ_1V8 - IO_L11N_T1U_N9_GC_67
set_property PACKAGE_PIN BE24     [get_ports "uart_tx_o"] ;# Bank  67 VCCO - VADJ_1V8 - IO_L9N_T1L_N7_GC_67
set_property IOSTANDARD  LVCMOS18 [get_ports "uart_tx_o"] ;# Bank  67 VCCO - VADJ_1V8 - IO_L9N_T1L_N7_GC_67

# JTAG routed on J53 PMOD male pin header (via level-shifter U42, VCC1V2_FPGA; UG1066 Table 1-33)
# PMOD1_0, J53.1 -> TMS
set_property PACKAGE_PIN P22     [get_ports jtag_tms_i]
set_property IOSTANDARD LVCMOS12 [get_ports jtag_tms_i]
# PMOD1_1, J53.3 -> TDI
set_property PACKAGE_PIN N22     [get_ports jtag_tdi_i]
set_property IOSTANDARD LVCMOS12 [get_ports jtag_tdi_i]
# PMOD1_2, J53.5 -> TDO
set_property PACKAGE_PIN J20     [get_ports jtag_tdo_o]
set_property IOSTANDARD LVCMOS12 [get_ports jtag_tdo_o]
# PMOD1_3, J53.7 -> TCK
set_property PACKAGE_PIN K24     [get_ports jtag_tck_i]
set_property IOSTANDARD LVCMOS12 [get_ports jtag_tck_i]

# Active-high CPU reset (bank 70/71 = VCC1V2_FPGA; UG1066 pinout XML index 28)
set_property PACKAGE_PIN E36     [get_ports sys_reset]
set_property IOSTANDARD LVCMOS12 [get_ports sys_reset]

# Clock diff @ 300 MHz (bank 57, sysclk1_300; UG1066 pinout XML index 29/30)
set_property IOSTANDARD LVDS [get_ports sys_clk_n]
set_property IOSTANDARD LVDS [get_ports sys_clk_p]
set_property PACKAGE_PIN G31 [get_ports sys_clk_p]
set_property PACKAGE_PIN F31 [get_ports sys_clk_n]

# tclint-enable line-length, spacing
